_verse_key":"2:3","quran_span_ref":"2:3","retrieval_method":null,"matched_terms":[]}}],"conversation":{"followup_ready":true,"anchors":[{"anchor_type":"quran_ref","source_domain":"quran","canonical_ref":"quran:2:1-286","display_text":"Quran 2:1-286"},{"anchor_type":"tafsir_section","source_domain":"tafsir","canonical_ref":"tafsir:ibn-kathir-en:82710","display_text":"Tafsir Ibn Kathir on Quran 2:99-103"},{"anchor_type":"tafsir_section","source_domain":"tafsir","canonical_ref":"tafsir:ibn-kathir-en:82693","display_text":"Tafsir Ibn Kathir on Quran 2:68-71"},{"anchor_type":"tafsir_section","source_domain":"tafsir","canonical_ref":"tafsir:ibn-kathir-en:82743","display_text":"Tafsir Ibn Kathir on Quran 2:159-162"},{"anchor_type":"tafsir_section","source_domain":"tafsir","canonical_ref":"tafsir:maarif-al-quran-en:79625","display_text":"Ma'arif al-Qur'an on Quran 2:17-20"},{"anchor_type":"tafsir_section","source_domain":"tafsir","canonical_ref":"tafsir:maarif-al-quran-en:79665","display_text":"Ma'arif al-Qur'an on Quran 2:68-71"},{"anchor_type":"tafsir_section","source_domain":"tafsir","canonical_ref":"tafsir:maarif-al-quran-en:79765","display_text":"Ma'arif al-Qur'an on Quran 2:204-207"},{"anchor_type":"tafsir_section","source_domain":"tafsir","canonical_ref":"tafsir:tafheem-al-quran-en:2:1","display_text":"Tafheem al-Quran on Quran 2:1"},{"anchor_type":"tafsir_section","source_domain":"tafsir","canonical_ref":"tafsir:tafheem-al-quran-en:2:2","display_text":"Tafheem al-Quran on Quran 2:2"},{"anchor_type":"tafsir_section","source_domain":"tafsir","canonical_ref":"tafsir:tafheem-al-quran-en:2:3","display_text":"Tafheem al-Quran on Quran 2:3"}]},"policy":{"source_policy":{"quran":{"domain":"quran","allowed":true,"included":true,"policy_reason":"selected","selected_capability":"explain_from_source","available_capabilities":["explicit_lookup","explain_from_source","quote_verification","conversation_followup_anchor"],"requested_text_source_id":"quran:tanzil-simple","requested_t
iases":{"include_tafsir":{"status":"compatibility_alias","canonical_field":"sources.tafsir.mode","notes":"Legacy flat compatibility field translated into canonical nested source controls."},"tafsir_source_id":{"status":"compatibility_alias","canonical_field":"sources.tafsir.source_ids[0]","notes":"Legacy flat compatibility field translated into canonical nested source controls."},"tafsir_limit":{"status":"compatibility_alias","canonical_field":"sources.tafsir.limit","notes":"Legacy flat compatibility field translated into canonical nested source controls."},"quran_text_source_id":{"status":"compatibility_alias","canonical_field":"sources.quran.text_source_id","notes":"Legacy flat compatibility field translated into canonical nested source controls."},"quran_translation_source_id":{"status":"compatibility_alias","canonical_field":"sources.quran.translation_source_id","notes":"Legacy flat compatibility field translated into canonical nested source controls."},"hadith_source_id":{"status":"compatibility_alias","canonical_field":"sources.hadith.collection_ids[0]","notes":"Legacy flat compatibility field translated into canonical nested source controls."},"debug":{"status":"compatibility_alias","canonical_field":"diagnostics.debug","notes":"Legacy flat compatibility field translated into canonical diagnostics controls."}}}},"interpretation":{"primary_intent":"source_grounded_quran_explanation_with_tafsir","secondary_intents":["reference_resolution","tafsir_request"],"query_class":"explicit_reference_with_modifier","confidence":0.98,"signals":["explicit_reference_parse","explain_language","tafsir_intent"],"route_reason":"explicit_quran_reference_detected","normalized_query":"surah al-ikhlas","route_type":"explicit_quran_reference","action_type":"explain"},"plan":{"plan_type":"quran_with_tafsir","eligible_domains":["quran","tafsir"],"selected_domains":["quran","tafsir"],"domain_decisions":[{"domain":"quran","eligible":true,"selected":true,"requested":true,"policy_reason":"selected","source_id":"quran:tanzil-simple","request_origin":"implicit_default","selected_capability":"explain_from_source","available_capabilities":["explicit_lookup","explain_from_source","quote_verification","conversation_followup_anchor"]},{"domain":"tafsir","eligible":true,"selected":true,"requested":true,"policy_reason":"selected_multiple","source_id":"tafsir:ibn-kathir-en","request_origin":"query_intent","selected_capability":"explain_from_source","available_capabilities":["composition_allowed","conversation_followup_anchor","explain_from_source","explicit_lookup","topical_retrieval"]},{"domain":"hadith","eligible":false,"selected":false,"requested":false,"policy_reason":"not_requested_for_route","source_id":null,"request_origin":null,"selected_capability":null,"available_capabilities":[]}],"abstain_reason":null,"notes":["tafsir_source:tafsir:ibn-kathir-en","tafsir_source:tafsir:maarif-al-quran-en","tafsir_source:tafsir:tafheem-al-quran-en"],"planner_version":"v1.6"},"answer":{"mode":"quran_with_tafsir","terminal_state":"answered","summary_text":"Quran 112:1-4 says: Say: 芒聙聹He is Allah, the One and Unique; Allah, Who is in need of none and of Whom all are in need; He neither begot any nor was He begotten, and none is comparable to Him.芒聙聺  \n\n**Tafsir Ibn Kathir** emphasizes that this Surah was revealed in Makkah. It was in response to the idolators who asked the Prophet Muhammad about the lineage of Allah. The Surah delineates Allah's unique attributes, highlighting His oneness and independence.  \n\n**Ma'arif al-Qur'an** also notes that the cause of revelation involved questions from the pagans of Makkah to the Messenger, asking about Allah's ancestry芒聙聰prompting the clear declaration of His nature.   \n\n**Tafheem al-Qur'an** explains that the command to \"Say\" is directed at the Prophet Muhammad, establishing him as Allah's messenger who is to convey this essential truth to others, emphasizing that Allah is the same being known to them, firmly distinguishing His singular nature.","blocks":[{"block_type":"quran_quote","domain":"quran","text":"Say: 芒聙聹He is Allah, the One and Unique; Allah, Who is in need of none and of Whom all are in need; He neither begot any nor was He begotten, and none is comparable to Him.芒聙聺","title":"Quran 112:1-4","citations":["quran:112:1-4"],"source_id":"quran:tanzil-simple"},{"block_type":"tafsir_support","domain":"tafsir","text":"Which was revealed in Makkah The Reason for the Revelation of this Surah and its Virtues Imam Ahmad recorded from Ubayy bin Ka`b that the idolators said to the Prophet , \"O Muhammad! Tell us the lineage of your Lord.\" So Allah revealed 脴篓脵聬脴鲁脵聮脵聟脵聬 脴搂脵聞脵聞脵聨脵聭脵聡脵聬 脴搂脵聞脴卤脵聨脵聭脴颅脵聮脵聟脵聨脵聙脵聠脵聬 脴搂脵聞脴卤脵聨脵聭脴颅脵聬脵聤脵聟脵聬 In the name of Allah, the Beneficent, the Merciful Similar was recorded by At-Tirmidhi and Ibn Jarir and they added in their narration that he said, 脴搂脵聞脴碌脵聨脵聭脵聟脵聨脴炉脵聫 (As-Samad) is One Who does not give birth, nor was He born, because there is nothing that is born except that it will die, and there is nothing that dies except that","title":"Tafsir Ibn Kathir on Quran 112:1-4","citations":["tafsir:ibn-kathir-en:84552"],"source_id":"tafsir:ibn-kathir-en"},{"block_type":"tafsir_support","domain":"tafsir","text":"Cause of Revelation Tirmidhi, Hakim and others have recorded that the pagans of Makkah asked the Messenger of Allah 脴碌脵聞脵聣 脴搂脵聞脵聞脵聡 脴鹿脵聞脵聤脵聡 脵聢脴鲁脵聞脵聟 : \"0 Muhammad! Tell us about the ancestry of your Lord.\" So Allah revealed this Surah. Some narratives ascribe this inquiry to the Jews of Madinah. In view of these conflicting reports, there is a divergence of opinion as to whether this is a Makki Surah or Madani Surah. According to Sayyidna ` Abdullah Ibn Masud, Hasan Basri, ` Ata', ` Ikrimah and Jabir 脴聯 脴聦 the Surah is Makki and, according to Qatadah, Dahhak 脴卤脴颅脵聟脹聝 脴搂脵聞脵聞脹聛 脴鹿脵聞脹聦脹聛脵聟脴搂 and others, it is Madani.","title":"Ma'arif al-Qur'an on Quran 112:1","citations":["tafsir:maarif-al-quran-en:82631"],"source_id":"tafsir:maarif-al-quran-en"},{"block_type":"tafsir_support","domain":"tafsir","text":"Verse [ 112:2] 脴搂脵聞脵聞脵聨脵聭脵聙脵聡脵聫 脴搂脵聞脴碌脵聨脵聭脵聟脵聨脴炉脵聫 (Allah is Besought of all, needing none) The word samad bears several literal senses. Therefore, the Qur'anic exegetical scholars have assigned different meanings to this verse. Tabarani, the leading authority on Prophetic Traditions, in his kitab-us-Sunnah, has collected all the interpretations of the Divine attribute As-samad and concluded that they are all authentic, and comprehend all the attributes of our Lord that have been assigned to Him, but originally it refers to 'the chief who has no superior and to whom the people turn for the fulfillment of their","title":"Ma'arif al-Qur'an on Quran 112:2","citations":["tafsir:maarif-al-quran-en:82632"],"source_id":"tafsir:maarif-al-quran-en"},{"block_type":"tafsir_support","domain":"tafsir","text":"Allah is Above having Children and Procreating Verse [ 112:3] 脵聞脵聨脵聟脵聮 脵聤脵聨脵聞脵聬脴炉脵聮 脵聢脵聨脵聞脵聨脵聟脵聮 脵聤脵聫脵聢脵聞脵聨脴炉脵聮 (He neither begot anyone, nor was begotten.) This verse responds to those who had questioned about the ancestry of Allah. There is no analogy between Allah, the Creator, and His creation. While His creation comes into being through the biological process of procreation, Allah Himself has no children, nor is He the child of anyone.","title":"Ma'arif al-Qur'an on Quran 112:3","citations":["tafsir:maarif-al-quran-en:82633"],"source_id":"tafsir:maarif-al-quran-en"},{"block_type":"tafsir_support","domain":"tafsir","text":"On \"Say:\": The first addressee of this command is the Prophet (peace be upon him) himself for it was he who was asked: Who is your Lord and what is He like. Again it was he who was commanded to answer the question in the following words. But after him every believer is its addressee. He too should say what the Prophet (peace be upon him) had been commanded to say. On \"芒聙聹He is Allah,\": That is, my Lord to Whom you want to be introduced is none but Allah.","title":"Tafheem al-Quran on Quran 112:1","citations":["tafsir:tafheem-al-quran-en:112:1"],"source_id":"tafsir:tafheem-al-quran-en"},{"block_type":"tafsir_support","domain":"tafsir","text":"On \"Allah, Who is in need of none and of Whom all are in need;\": The word used in the original is samad of which the root is smd. A look at the derivatives in Arabic from this root will show how comprehensive and vast this word is in meaning. (Lexical discussion of the meanings of the derivatives is omitted).","title":"Tafheem al-Quran on Quran 112:2","citations":["tafsir:tafheem-al-quran-en:112:2"],"source_id":"tafsir:tafheem-al-quran-en"},{"block_type":"tafsir_support","domain":"tafsir","text":"On \"He neither begot any nor was He begotten,\": The polytheists in every age have adopted the concept that like men, gods also belong to a species, which has many members and they also get married, beget and are begotten. They did not even regard Allah, Lord of the universe, as supreme and above this concept of ignorance, and even proposed children for Him. Thus, the Arabian belief as stated in the Quran was that they regarded the angels as daughters of Allah. The Prophetic communities too could not remain immune from this creed of paganism.","title":"Tafheem al-Quran on Quran 112:3","citations":["tafsir:tafheem-al-quran-en:112:3"],"source_id":"tafsir:tafheem-al-quran-en"}]},"evidence":[{"evidence_type":"quran_span","domain":"quran","source_id":"quran:tanzil-simple","canonical_ref":"quran:112:1-4","citation_text":"Quran 112:1-4","payload":{"surah_no":112,"ayah_start":1,"ayah_end":4,"surah_name_en":"al-ikhlas","surah_name_ar":"脴搂脵聞脴楼脴庐脵聞脴搂脴碌","translation_source_id":"quran:towards-understanding-en"}},{"evidence_type":"tafsir_section","domain":"tafsir","source_id":"tafsir:ibn-kathir-en","canonical_ref":"tafsir:ibn-kathir-en:84552","citation_text":"Tafsir Ibn Kathir on Quran 112:1-4","payload":{"surah_no":112,"ayah_start":1,"ayah_end":4,"coverage_mode":"inferred_from_empty_followers","coverage_confidence":0.95,"anchor_ver